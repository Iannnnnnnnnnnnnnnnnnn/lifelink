TZ=Asia/Shanghai

# Web
WEB_PORT=80
VITE_API_BASE_URL=
NGINX_CLIENT_MAX_BODY_SIZE=50m

# PostgreSQL
POSTGRES_DB=lifelink
POSTGRES_USER=lifelink
POSTGRES_PASSWORD=change-this-postgres-password

# Redis
SPRING_REDIS_DATABASE=0

# JWT
# Use a long random secret, at least 32 bytes.
LIFELINK_JWT_SECRET=change-this-to-a-long-random-production-secret-at-least-32-bytes
LIFELINK_JWT_EXPIRATION=604800000

# MinIO
MINIO_ROOT_USER=lifelink_minio
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
LIFELINK_MINIO_BUCKET=lifelink

# Internal endpoint used by backend containers to connect to MinIO.
LIFELINK_MINIO_ENDPOINT=http://minio:9000
# Public endpoint saved into uploaded file URLs and used by browsers.
LIFELINK_MINIO_PUBLIC_ENDPOINT=http://47.97.202.182

# Optional standalone reverse-proxy template value.
SERVER_NAME=_
