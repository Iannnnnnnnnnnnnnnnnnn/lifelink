TZ=Asia/Shanghai

# Web
WEB_PORT=80
VITE_API_BASE_URL=
NGINX_CLIENT_MAX_BODY_SIZE=50m

# HTTPS / domains
# Same-origin web + API can leave VITE_API_BASE_URL and LIFELINK_CORS_ALLOWED_ORIGINS empty.
# If web and API use different domains, set both to HTTPS origins, e.g.:
# VITE_API_BASE_URL=https://api.example.com
# LIFELINK_CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
LIFELINK_CORS_ALLOWED_ORIGINS=

# PostgreSQL
POSTGRES_DB=lifelink
POSTGRES_USER=lifelink
POSTGRES_PASSWORD=change-this-postgres-password

# Redis
SPRING_REDIS_DATABASE=0

# JWT
# Use a long random secret, at least 32 bytes.
LIFELINK_JWT_SECRET=change-this-to-a-long-random-production-secret-at-least-32-bytes
LIFELINK_JWT_EXPIRATION=604800000

# MinIO
MINIO_ROOT_USER=lifelink_minio
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
LIFELINK_MINIO_BUCKET=lifelink

# Internal endpoint used by backend containers to connect to MinIO.
LIFELINK_MINIO_ENDPOINT=http://minio:9000

# Public endpoint stored in uploaded file URLs and returned to browsers.
LIFELINK_MINIO_PUBLIC_ENDPOINT=https://memoryspace.online

# Feature flags
# Production should set the real comma-separated allowed phone list.
LIFELINK_PHILOSOPHY_ALLOWED_PHONES=
# Backward-compatible fallback for older deployments.
LIFELINK_PSYCHOLOGY_TEACHER_ALLOWED_PHONES=

# Focus Coins / Reward Center
LIFELINK_REWARD_ADMIN_PHONES=15948981889
LIFELINK_FOCUS_COIN_ENABLED=true
LIFELINK_FOCUS_COIN_UNIT_MINUTES=5
LIFELINK_FOCUS_COIN_PER_UNIT=2
LIFELINK_FOCUS_COIN_MAX_MINUTES_PER_SESSION=120
LIFELINK_FOCUS_COIN_DAILY_CAP=

# AI. Leave AI_API_KEY empty or set AI_MOCK=true to use mock mode.
AI_ENABLED=true
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=sk-your-deepseek-api-key
AI_MODEL=deepseek-v4-flash
AI_TIMEOUT_SECONDS=60
AI_MAX_TOKENS=1200
AI_TEMPERATURE=0.7
AI_MOCK=false
AI_CHAT_CONTEXT_MESSAGES=16
AI_CHAT_MAX_USER_MESSAGE_LENGTH=2000

# Cycle Care daily advice job
LIFELINK_CYCLE_CARE_DAILY_ADVICE_ENABLED=true
LIFELINK_CYCLE_CARE_DAILY_ADVICE_CRON=0 5 0 * * ?
LIFELINK_CYCLE_CARE_DAILY_ADVICE_ZONE=Asia/Shanghai
LIFELINK_CYCLE_CARE_DAILY_ADVICE_USE_AI=true
LIFELINK_CYCLE_CARE_DAILY_ADVICE_MAX_REGENERATE_DAYS=30

# Optional standalone reverse-proxy template value.
SERVER_NAME=example.com
SSL_CERTIFICATE=/etc/nginx/certs/fullchain.pem
SSL_CERTIFICATE_KEY=/etc/nginx/certs/privkey.pem
